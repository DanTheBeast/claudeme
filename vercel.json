{
  "rewrites": [
    {
      "source": "/friends",
      "destination": "/"
    },
    {
      "source": "/friends/",
      "destination": "/"
    },
    {
      "source": "/schedule",
      "destination": "/"
    },
    {
      "source": "/schedule/",
      "destination": "/"
    },
    {
      "source": "/profile",
      "destination": "/"
    },
    {
      "source": "/profile/",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ]
}
